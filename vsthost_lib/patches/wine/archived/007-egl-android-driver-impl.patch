+/* Each wine wgl context is wrapped so we can attach a pbuffer surface at
+ * make_current time. The void* `private` slot of wine's driver protocol
+ * stores this wrapper. */
+struct egldrv_context
+{
+    EGLContext ctx;
+    EGLSurface surface;  /* owned pbuffer used when no HDC-specific surface */
+    EGLConfig config;
+};
+
+static EGLConfig egldrv_config_for_format( int format )
+{
+    struct egl_platform *egl = &display_egl;
+    int idx;
+    if (!egl->config_count) return EGL_NO_CONFIG_KHR;
+    idx = format - 1;
+    if (idx < 0) idx = 0;
+    return egl->configs[idx % egl->config_count];
+}
