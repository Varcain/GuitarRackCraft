+/* vstpoc patch 027: cross-thread focus/activation messages must be
+ * fire-and-forget on real Windows (cross-thread WM_SETFOCUS / WM_KILLFOCUS
+ * / WM_NCACTIVATE / WM_ACTIVATE / WM_ACTIVATEAPP use SendNotifyMessage
+ * semantics). Patch 026 used send_message_timeout with a 2s deadline,
+ * but that still stalls the sender for up to 2s × N sites per popup
+ * interaction (~16s observed on JUCE-7 plugins). Mirror the proven
+ * pattern wine itself uses in set_foreground_window — NtUserMessageCall
+ * with NtUserSendNotifyMessage — so cross-thread sends never block.
+ *
+ * Same-thread sends stay synchronous: the WindowProc must run before
+ * the caller continues (e.g. WM_SETFOCUS feeding back into edit controls).
+ *
+ * Rollback gate WINE_VSTPOC_SYNC_FOCUS=1 restores patch 026's
+ * send_message_timeout path for emergency debugging without a rebuild. */
+static BOOL vstpoc_sync_focus( void )
+{
+    static int checked = 0, sync = 0;
+    if (!checked)
+    {
+        const char *e = getenv("WINE_VSTPOC_SYNC_FOCUS");
+        sync = (e && *e && *e != '0');
+        checked = 1;
+    }
+    return sync;
+}
+
+static void send_focus_message_async( HWND hwnd, UINT msg, WPARAM wp, LPARAM lp )
+{
+    if (get_window_thread( hwnd, NULL ) == GetCurrentThreadId())
+        send_message( hwnd, msg, wp, lp );
+    else if (vstpoc_sync_focus())
+        send_message_timeout( hwnd, msg, wp, lp, SMTO_NORMAL, 2000, FALSE );
+    else
+        NtUserMessageCall( hwnd, msg, wp, lp, 0, NtUserSendNotifyMessage, FALSE );
+}
+
