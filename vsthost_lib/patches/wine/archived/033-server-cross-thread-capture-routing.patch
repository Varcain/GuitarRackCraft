+/* vstpoc patch 033: scan all thread_inputs on the desktop for any active
+ * pointer capture and return its window + owning thread. Windows' SetCapture
+ * is conceptually desktop-wide, but wine stores it per-thread_input. When a
+ * cross-thread popup (e.g. JUCE 7's PopupMenu) holds capture, the desktop's
+ * foreground_input doesn't see it, so mouse events route to the parent
+ * window's thread and the popup never receives the click that should
+ * dismiss it. This helper recovers the desktop-wide capture target. */
+static user_handle_t vstpoc_find_any_thread_capture( struct desktop *desktop, struct thread **out_thread )
+{
+    struct thread_input *ti;
+    user_handle_t cap;
+
+    LIST_FOR_EACH_ENTRY( ti, &desktop->inputs, struct thread_input, desktop_entry )
+    {
+        if (!ti->shared) continue;
+        cap = ti->shared->capture;
+        if (!cap) continue;
+        *out_thread = get_window_thread( cap );
+        return cap;
+    }
+    *out_thread = NULL;
+    return 0;
+}
