+/* vstpoc patch 028: drop posted WM_USER+N if the target queue already
+ * has >= threshold pending of the same (hwnd, msg). Defeats the JUCE-
+ * on-FEX callback-storm livelock where TH-U's MessageManager thread
+ * spins at 80% CPU forever draining WM_USER+123 that worker threads
+ * post faster than FEX can dispatch.
+ *
+ * Threshold is per (hwnd, msg) — different msg IDs to the same hwnd
+ * each have their own quota, so legitimate distinct callbacks aren't
+ * starved.
+ *
+ * Lossy by design: dropped messages = dropped JUCE async callbacks.
+ * The receiver plugin may end up in inconsistent state. Trade off
+ * accepted because the alternative is the host being permanently CPU-
+ * bound with no recovery possible. Default OFF; enable with
+ * WINE_VSTPOC_COALESCE_POSTS=<threshold>, e.g. 200. */
+static int vstpoc_coalesce_threshold( void )
+{
+    static int checked = 0, threshold = 0;
+    if (!checked)
+    {
+        const char *e = getenv("WINE_VSTPOC_COALESCE_POSTS");
+        threshold = (e && *e) ? atoi(e) : 0;
+        if (threshold < 0) threshold = 0;
+        checked = 1;
+    }
+    return threshold;
+}
+
+static int vstpoc_should_drop_post( struct msg_queue *queue, struct message *msg )
+{
+    int threshold = vstpoc_coalesce_threshold();
+    struct message *m;
+    int matches = 0, scanned = 0;
+
+    if (threshold <= 0) return 0;
+    if (msg->msg < 0x400) return 0;  /* only the WM_USER+N range */
+
+    /* Scan the receiver's posted-message list, capped to avoid O(huge)
+     * per post when the queue is already saturated. If we find threshold
+     * matches in the first 8192 entries, that's signal enough — drop. */
+    LIST_FOR_EACH_ENTRY( m, &queue->msg_list[POST_MESSAGE], struct message, entry )
+    {
+        if (++scanned > 8192) break;
+        if (m->msg == msg->msg && m->win == msg->win)
+        {
+            if (++matches >= threshold)
+            {
+                static int last_warn_msg = -1;
+                static user_handle_t last_warn_win = 0;
+                if (last_warn_msg != (int)msg->msg || last_warn_win != msg->win)
+                {
+                    fprintf( stderr, "vstpoc 028: coalescing posts hwnd=%08x "
+                             "msg=0x%04x (>= %d pending — dropping further posts)\n",
+                             msg->win, msg->msg, threshold );
+                    last_warn_msg = msg->msg;
+                    last_warn_win = msg->win;
+                }
+                return 1;
+            }
+        }
+    }
+    return 0;
+}
