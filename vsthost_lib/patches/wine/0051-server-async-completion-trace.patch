     struct object        obj;                 /* object header */
@@ -489,6 +491,10 @@ obj_handle_t async_handoff( struct async *async, data_size_t *result, int force_
         }
     }
     async->initial_status = async->iosb->status;
+    if (async->data.apc_context && vstpoc_async_trace())
+        fprintf( stderr, "vstpoc-async: HANDOFF async=%p fd=%p cval=%llx st=%x pend=%u\n",
+                 async, async->fd, (unsigned long long)async->data.apc_context,
+                 async->iosb->status, async->pending );
     set_error( async->iosb->status );
     return async->wait_handle;
 }
@@ -555,6 +561,16 @@ void async_set_completion_callback( struct async *async, async_completion_callba
     async->completion_callback_private = private;
 }
 
+/* vstpoc: env-gated tracing for the lost-IOCP-packet hunt (IK PM channel wedge).
+ * Logs every IOCP-relevant async (apc_context set) at handoff + completion so a
+ * skipped packet is visible. Enable with VSTPOC_ASYNC_TRACE=1 in wineserver env. */
+int vstpoc_async_trace(void)
+{
+    static int on = -1;
+    if (on < 0) { const char *e = getenv( "VSTPOC_ASYNC_TRACE" ); on = e && *e != '0'; }
+    return on;
+}
+
 static void add_async_completion( struct async *async, apc_param_t cvalue, unsigned int status,
                                   apc_param_t information )
 {
@@ -620,8 +636,18 @@ void async_set_result( struct object *obj, unsigned int status, apc_param_t tota
             else if (async->data.apc_context && (async->pending ||
                      !(async->comp_flags & FILE_SKIP_COMPLETION_PORT_ON_SUCCESS)))
             {
+                if (vstpoc_async_trace())
+                    fprintf( stderr, "vstpoc-async: PACKET async=%p fd=%p cval=%llx st=%x tot=%llx pend=%u flags=%x\n",
+                             async, async->fd, (unsigned long long)async->data.apc_context, status,
+                             (unsigned long long)total, async->pending, async->comp_flags );
                 add_async_completion( async, async->data.apc_context, status, total );
             }
+            else if (async->data.apc_context && vstpoc_async_trace())
+            {
+                fprintf( stderr, "vstpoc-async: SKIPPED async=%p fd=%p cval=%llx st=%x tot=%llx pend=%u flags=%x\n",
+                         async, async->fd, (unsigned long long)async->data.apc_context, status,
+                         (unsigned long long)total, async->pending, async->comp_flags );
+            }
 
             if (async->event) set_event( async->event );
             else if (async->fd && !async->is_system) set_fd_signaled( async->fd, 1 );
