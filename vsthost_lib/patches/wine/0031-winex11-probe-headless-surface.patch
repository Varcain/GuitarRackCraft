--- a/dlls/winex11.drv/vulkan.c
+++ b/dlls/winex11.drv/vulkan.c
@@ -152,6 +152,31 @@
      * Vulkan bridge) is the one actually loaded, not a stale cached copy. */
     ERR( "vstpoc: winex11 Android Vulkan bridge ACTIVE (android_surface + stub)\n" );
 
+    /* vstpoc: probe whether the host Vulkan loader exposes VK_EXT_headless_surface
+     * (+ android_surface). Turnip implements headless, but the Android system
+     * Vulkan loader (which adrenotools wraps) curates instance extensions and may
+     * not pass it through. A real headless surface would replace the stub so
+     * D3D11 editor swapchains succeed (no ANativeWindow needed). */
+    {
+        PFN_vkEnumerateInstanceExtensionProperties p_enum =
+            dlsym( vulkan_handle, "vkEnumerateInstanceExtensionProperties" );
+        if (p_enum)
+        {
+            static VkExtensionProperties props[400];
+            uint32_t n = 400, i, headless = 0, android = 0, display = 0;
+            if (!p_enum( NULL, &n, props ))
+                for (i = 0; i < n && i < 400; i++)
+                {
+                    if (!strcmp( props[i].extensionName, "VK_EXT_headless_surface" )) headless = 1;
+                    if (!strcmp( props[i].extensionName, "VK_KHR_android_surface" )) android = 1;
+                    if (!strcmp( props[i].extensionName, "VK_KHR_display" )) display = 1;
+                }
+            ERR( "vstpoc: host instance exts (n=%u): headless_surface=%u android_surface=%u display=%u\n",
+                 n, headless, android, display );
+        }
+        else ERR( "vstpoc: headless probe — no vkEnumerateInstanceExtensionProperties\n" );
+    }
+
     *driver_funcs = &x11drv_vulkan_driver_funcs;
     return STATUS_SUCCESS;
 }
