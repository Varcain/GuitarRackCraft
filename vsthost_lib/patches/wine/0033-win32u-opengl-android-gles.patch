     }
 
+    funcs->p_glBindFramebuffer( GL_READ_FRAMEBUFFER, old_read_fbo == (GLint)fbo ? 0 : old_read_fbo );
     funcs->p_glDeleteFramebuffers( 1, &fbo );
     TRACE( "drawable %p destroyed framebuffer %u\n", drawable, fbo );
 }
