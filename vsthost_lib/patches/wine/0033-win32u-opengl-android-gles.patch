 static BOOL framebuffer_surface_swap( struct opengl_drawable *drawable )
 {
+    /* vstpoc-gles: PRESENT the offscreen framebuffer to the window. On Android
+     * there is no EGL window surface behind the X11 window (it lives in our
+     * in-process X server), so read the pixels back and blit them through GDI —
+     * the window surface then reaches the X server via the normal XPutImage
+     * path and gets composited like any other editor content. */
+    const struct opengl_funcs *funcs = &display_funcs;
+    HWND hwnd = drawable->client ? drawable->client->hwnd : 0;
+    GLint old_read_fbo = 0;
+    char info_buf[sizeof(BITMAPINFOHEADER) + 4 * sizeof(RGBQUAD)];
+    BITMAPINFO *info = (BITMAPINFO *)info_buf;
+    UINT *bits;
+    RECT rect;
+    int width, height;
+    HDC hdc;
+    static int vstpoc_n;  /* vstpoc-gl TEMP diag */
+
     TRACE( "%s\n", debugstr_opengl_drawable( drawable ) );
+
+    if (!hwnd || !drawable->read_fbo) return TRUE;
+
+    NtUserGetClientRect( hwnd, &rect, NtUserGetDpiForWindow( hwnd ) );
+    width  = rect.right  > 0 ? rect.right  : 1;
+    height = rect.bottom > 0 ? rect.bottom : 1;
+
+    if (!(bits = malloc( (size_t)width * height * 4 ))) return FALSE;
+
+    funcs->p_glGetIntegerv( GL_READ_FRAMEBUFFER_BINDING, &old_read_fbo );
+
+    /* resolve a multisampled draw fbo into the single-sample read fbo */
+    if (drawable->draw_fbo && drawable->draw_fbo != drawable->read_fbo)
+    {
+        GLint old_draw_fbo = 0;
+        funcs->p_glGetIntegerv( GL_DRAW_FRAMEBUFFER_BINDING, &old_draw_fbo );
+        funcs->p_glBindFramebuffer( GL_READ_FRAMEBUFFER, drawable->draw_fbo );
+        funcs->p_glBindFramebuffer( GL_DRAW_FRAMEBUFFER, drawable->read_fbo );
+        funcs->p_glBlitFramebuffer( 0, 0, width, height, 0, 0, width, height, GL_COLOR_BUFFER_BIT, GL_NEAREST );
+        funcs->p_glBindFramebuffer( GL_DRAW_FRAMEBUFFER, old_draw_fbo );
+    }
+
+    funcs->p_glBindFramebuffer( GL_READ_FRAMEBUFFER, drawable->read_fbo );
+    /* vstpoc-gl: the drawn frame always lands in COLOR_ATTACHMENT0 — create_framebuffer
+     * sets glDrawBuffers={ATTACHMENT0}, and the MSAA resolve above blits into the
+     * read_fbo's draw buffer (also ATTACHMENT0). For a doublebuffer surface the FBO's
+     * *read* buffer is left at ATTACHMENT1 (the emulated front), which we never
+     * populate (there's no flip/copy on swap) so it reads back all-black. Read the
+     * attachment that actually holds the frame. (Replaces a temp self-heal probe that
+     * only ran for the first 8 frames, which is why AmpliTube went black on frame 9.) */
+    if (drawable->doublebuffer) funcs->p_glReadBuffer( GL_COLOR_ATTACHMENT0 );
+    funcs->p_glPixelStorei( GL_PACK_ALIGNMENT, 4 );
+    funcs->p_glReadPixels( 0, 0, width, height, GL_RGBA, GL_UNSIGNED_BYTE, bits );
+    funcs->p_glBindFramebuffer( GL_READ_FRAMEBUFFER, old_read_fbo );
+
+    /* RGBA -> BGRA for the 32bpp DIB (GLES has no GL_BGRA readback in core) */
+    for (size_t i = 0, total = (size_t)width * height; i < total; i++)
+    {
+        UINT c = bits[i];
+        bits[i] = (c & 0xff00ff00) | ((c & 0x00ff0000) >> 16) | ((c & 0x000000ff) << 16);
+    }
+
+    memset( info_buf, 0, sizeof(info_buf) );
+    info->bmiHeader.biSize        = sizeof(info->bmiHeader);
+    info->bmiHeader.biWidth       = width;
+    info->bmiHeader.biHeight      = height;  /* bottom-up DIB == glReadPixels row order, no flip */
+    info->bmiHeader.biPlanes      = 1;
+    info->bmiHeader.biBitCount    = 32;
+    info->bmiHeader.biCompression = BI_RGB;
+    info->bmiHeader.biSizeImage   = width * height * 4;
+
+    if ((hdc = NtUserGetDCEx( hwnd, 0, DCX_CACHE | DCX_USESTYLE )))
+    {
+        NtGdiSetDIBitsToDeviceInternal( hdc, 0, 0, width, height, 0, 0, 0, height,
+                                        (void *)bits, info, DIB_RGB_COLORS,
+                                        width * height * 4, sizeof(info_buf), FALSE, NULL );
+        NtUserReleaseDC( hwnd, hdc );
+    }
+    free( bits );
+
+    if (vstpoc_n++ < 8)
+        ERR( "vstpoc-gl: framebuffer_surface_swap PRESENT #%d hwnd=%p %dx%d read_fbo=%u\n",
+             vstpoc_n, hwnd, width, height, drawable->read_fbo );
     return TRUE;
 }
 
