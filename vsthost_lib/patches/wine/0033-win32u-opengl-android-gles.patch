+     * can't use → white screen. Ensure EGL_CONTEXT_MAJOR_VERSION is present and
+     * in [2,3]; default/clamp to GLES 3.0 (≈ desktop GL 3.3 core feature set). */
+    {
+        EGLint *maj = NULL, *mn = NULL, *p;
+        for (p = egl_attribs; p < attribs_end; p += 2)
+        {
+            if (p[0] == EGL_CONTEXT_MAJOR_VERSION_KHR) maj = p + 1;
+            else if (p[0] == EGL_CONTEXT_MINOR_VERSION_KHR) mn = p + 1;
+        }
+        if (!maj)
+        {
+            assert( attribs_end - egl_attribs <= ARRAY_SIZE(egl_attribs) - 3 );
+            attribs_end[0] = EGL_CONTEXT_MAJOR_VERSION_KHR;
+            attribs_end[1] = 3;
+            attribs_end += 2;
+            *attribs_end = EGL_NONE;
+        }
+        else if (*maj < 2 || *maj > 3)
