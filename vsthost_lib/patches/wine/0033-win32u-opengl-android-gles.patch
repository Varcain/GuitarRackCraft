+     * passes NULL here every frame, turning a one-time failure into a permanent
+     * make-current loop (AmpliTube white screen). */
+    if (!drawable || !drawable->funcs->set_context) return;
     drawable->funcs->set_context( drawable, context ? context->driver_private : NULL );
 }
 
