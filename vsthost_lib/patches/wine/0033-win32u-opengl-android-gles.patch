+            name = g_vstpoc_mesa_egl ? EGL_CONTEXT_OPENGL_PROFILE_MASK_KHR : EGL_NONE;
             break;
         default:
             name = EGL_NONE;
@@ -811,6 +978,54 @@ static BOOL egldrv_context_create( int format, void *share, const int *attribs,
     }
     *attribs_end = EGL_NONE;
 
+    if (g_vstpoc_mesa_egl)
+    {
+        /* Desktop GL (Zink): honor the app's requested version; if wine's legacy
+         * wglCreateContext passed none, default to 3.2 — enough for JUCE's
+         * desktop-GLSL shaders (the whole point of the Zink path). Do NOT clamp
+         * to GLES [2,3]. */
+        EGLint *maj = NULL, *p;
+        for (p = egl_attribs; p < attribs_end; p += 2)
+            if (p[0] == EGL_CONTEXT_MAJOR_VERSION_KHR) maj = p + 1;
+        if (!maj)
+        {
+            assert( attribs_end - egl_attribs <= ARRAY_SIZE(egl_attribs) - 5 );
+            attribs_end[0] = EGL_CONTEXT_MAJOR_VERSION_KHR; attribs_end[1] = 3;
+            attribs_end[2] = EGL_CONTEXT_MINOR_VERSION_KHR; attribs_end[3] = 2;
+            attribs_end += 4;
+            *attribs_end = EGL_NONE;
+        }
+    }
+    else
+    {
+    /* vstpoc: force a MODERN GLES version. wine's legacy wglCreateContext passes
+     * no version attribs → eglCreateContext(EGL_OPENGL_ES_API) defaults to GLES
