From: Kamil Lulko <limakzagan@gmail.com>
Subject: winex11: key-arrival diagnostic (DEBUG ONLY — remove before shipping)

vstpoc_key_log writes cache/key.log on every X11DRV_KeyEvent (keycode/keysym/vkey/char/focus) for the BIAS CEF input dig. Pure diagnostic — strip before shipping.

diff --git a/dlls/winex11.drv/keyboard.c b/dlls/winex11.drv/keyboard.c
index 65de84678ec..78dd517cfff 100644
--- a/dlls/winex11.drv/keyboard.c
+++ b/dlls/winex11.drv/keyboard.c
@@ -63,6 +63,26 @@
     scancode %x
 */
 WINE_DEFAULT_DEBUG_CHANNEL(keyboard);
+
+/* vstpoc: log key arrival directly to a file (CEF subprocess stderr is lost). */
+#include <fcntl.h>
+#include <unistd.h>
+#include <stdio.h>
+static void vstpoc_key_log( const char *fmt, ... )
+{
+    static int fd = -2;
+    char buf[512];
+    va_list ap;
+    int n;
+    if (fd == -2)
+        fd = open( "/data/data/com.varcain.guitarrackcraft/cache/key.log",
+                   O_WRONLY | O_APPEND | O_CREAT, 0644 );
+    if (fd < 0) return;
+    va_start( ap, fmt );
+    n = vsnprintf( buf, sizeof(buf), fmt, ap );
+    va_end( ap );
+    if (n > 0) write( fd, buf, n < (int)sizeof(buf) ? n : (int)sizeof(buf) );
+}
 WINE_DECLARE_DEBUG_CHANNEL(key);
 
 static const unsigned int ControlMask = 1 << 2;
@@ -1429,6 +1449,12 @@ BOOL X11DRV_KeyEvent( HWND hwnd, XEvent *xev )
     if (!vkey && ascii_chars) vkey = VK_NONAME;
     bScan = keyc2scan[event->keycode] & 0xFF;
 
+    vstpoc_key_log( "KEY %s win=%lx hwnd=%p kc=%u keysym=%lx vkey=%04x chars=%d '%.*s' focus=%p fg=%p\n",
+                    event->type == KeyPress ? "DOWN" : "UP", (unsigned long)event->window, hwnd,
+                    event->keycode, (unsigned long)keysym, vkey, ascii_chars,
+                    ascii_chars > 0 ? ascii_chars : 0, buf,
+                    get_focus(), NtUserGetForegroundWindow() );
+
     TRACE_(key)("keycode %u converted to vkey 0x%X scan %02x\n",
                 event->keycode, vkey, bScan);
 
