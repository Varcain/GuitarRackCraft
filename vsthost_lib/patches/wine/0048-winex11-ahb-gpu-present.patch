+/* Phase 3 GPU path: ship the freshest frame's AHardwareBuffer + acquire-fence
+ * over the side-channel — no CPU readback. The AImage is HELD (1-deep) until the
+ * next frame so DXVK can't reuse its buffer while the X server samples it; the
+ * previous held image is returned to the pool here. REGISTER replaces the
+ * window's single buffer each frame (the AImageReader's 4 buffers cycle), then
+ * PRESENT(index 0) with the fence the X server GPU-waits before sampling.
+ * Returns 1 if it handled the frame, 0 to fall back to CPU readback. */
+static int vstpoc_present_ahb( struct vstpoc_surface_ctx *s, void *reader )
+{
+    void *image = NULL, *ahb = NULL;
+    int fence_fd = -1, ok = 0;
+    AhbChMsg msg;
+
+    if (s->chan_fd < 0 || !p_AImage_getHardwareBuffer || !p_AHardwareBuffer_sendHandleToUnixSocket)
+        return 0;
+
+    if (p_AImageReader_acquireLatestImageAsync)
+    {
+        if (p_AImageReader_acquireLatestImageAsync( reader, &image, &fence_fd ) != 0 || !image) return 0;
+    }
+    else if (p_AImageReader_acquireLatestImage( reader, &image ) != 0 || !image) return 0;
+
+    if (p_AImage_getHardwareBuffer( image, &ahb ) != 0 || !ahb) goto done;
+
+    /* REGISTER (buffer_count=1, replaces) + the AHB handle (SCM_RIGHTS). */
+    memset( &msg, 0, sizeof(msg) );
+    msg.magic = AHBCH_MAGIC; msg.version = AHBCH_VERSION; msg.type = AHBCH_REGISTER;
+    msg.window_id = s->window_id; msg.width = s->width; msg.height = s->height;
+    msg.format = 1 /* AHARDWAREBUFFER_FORMAT_R8G8B8A8_UNORM */; msg.buffer_count = 1;
+    if (!ahbch_send_msg( s->chan_fd, &msg, -1 )) goto chan_broken;
+    if (p_AHardwareBuffer_sendHandleToUnixSocket( ahb, s->chan_fd ) != 0) goto chan_broken;
+
+    /* PRESENT(index 0) with the acquire-fence. */
+    memset( &msg, 0, sizeof(msg) );
+    msg.magic = AHBCH_MAGIC; msg.version = AHBCH_VERSION; msg.type = AHBCH_PRESENT;
+    msg.window_id = s->window_id; msg.buffer_index = 0; msg.has_fence = (fence_fd >= 0);
+    if (!ahbch_send_msg( s->chan_fd, &msg, fence_fd )) goto chan_broken;
+    ok = 1;
+
+    /* Hold THIS image; release the previous one back to the swapchain pool. */
+    if (s->held_image) p_AImage_delete( s->held_image );
+    s->held_image = image;
+    image = NULL;
+    goto done;
+
+chan_broken:
+    ERR( "vstpoc: AHB side-channel send failed (%s) — reverting to CPU readback\n", strerror(errno) );
+    close( s->chan_fd );
+    s->chan_fd = -1;
+    s->ahb_present = 0;
+
+done:
+    if (fence_fd >= 0) close( fence_fd );   /* SCM_RIGHTS dup'd it; close our copy */
+    if (image) p_AImage_delete( image );
+    return ok;
+}
