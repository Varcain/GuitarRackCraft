+        send_focus_message( previous, WM_NCACTIVATE, FALSE, (LPARAM)hwnd );
+        send_focus_message( previous, WM_ACTIVATE,
+                            MAKEWPARAM( WA_INACTIVE, is_iconic(previous) ? 0x20 : 0 ),
+                            (LPARAM)hwnd );
     }
 
     SERVER_START_REQ( set_active_window )
