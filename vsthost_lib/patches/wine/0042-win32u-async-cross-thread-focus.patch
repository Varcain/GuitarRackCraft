             if (new_thread)
@@ -2061,7 +2093,7 @@ BOOL set_active_window( HWND hwnd, HWND *prev, BOOL mouse, BOOL focus, DWORD new
                 for (phwnd = list; *phwnd; phwnd++)
                 {
