+#include <stdlib.h>
+#include <string.h>
+#include <errno.h>
+#include <sys/socket.h>
+#include <sys/un.h>
 
 #include "ntstatus.h"
 #include "ntgdi_private.h"
@@ -37,6 +42,14 @@
 
 #include "dibdrv/dibdrv.h"
 
+/* vstpoc GL zero-copy present: GPU-blit the editor's rendered FBO into an
