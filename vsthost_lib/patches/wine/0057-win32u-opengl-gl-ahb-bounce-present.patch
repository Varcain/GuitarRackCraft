+static void vstpoc_gl_ahb_free( struct framebuffer_surface *s );  /* fwd: defined with the present path */
+
 static void framebuffer_surface_destroy( struct opengl_drawable *drawable )
 {
+    struct framebuffer_surface *s = (struct framebuffer_surface *)drawable;
     TRACE( "%s\n", debugstr_opengl_drawable( drawable ) );
+    /* vstpoc: tear down the AHB-bounce side-channel; closing it makes the X server
+     * revert the editor window to the CPU framebuffer (see handleAhbChannelConnection
+     * end-of-connection). UNREGISTER is best-effort (the close suffices). */
+    if (s->ahb_tried && s->ahb_chan_fd >= 0)
+    {
+        AhbChMsg msg;
+        memset( &msg, 0, sizeof(msg) );
+        msg.magic = AHBCH_MAGIC; msg.version = AHBCH_VERSION; msg.type = AHBCH_UNREGISTER;
+        msg.window_id = s->ahb_window_id;
+        ahbch_send_msg( s->ahb_chan_fd, &msg, -1 );
+        close( s->ahb_chan_fd );
+        s->ahb_chan_fd = -1;
+    }
+    vstpoc_gl_ahb_free( s );
 }
 
