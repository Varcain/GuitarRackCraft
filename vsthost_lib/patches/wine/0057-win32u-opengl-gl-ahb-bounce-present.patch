+ * Vendored verbatim from vsthost_lib/src/main/cpp/x11/AhbChannelProtocol.h —
+ * KEEP IN SYNC (the X server + the winex11.drv Vulkan producer are the other
+ * ends). POSIX sockets only, no NDK headers. See feedback_gl_zerocopy_dmabuf_not_ahb. */
+#include "AhbChannelProtocol.h"
+
 WINE_DEFAULT_DEBUG_CHANNEL(wgl);
 
