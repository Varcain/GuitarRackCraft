+/* vstpoc patch 025: detect JUCE-7 popup-close cross-thread SendMessage cycle
+ * and break it by synthesizing a 0-reply once the receiver has held the
+ * focus-class message past the threshold without replying. Two-phase: first
+ * timeout wakes the receiver queue (covers "just slow" cases, common on FEX);
+ * second timeout synthesizes the 0-reply (covers truly stuck cases).
+ * Gated by env var WINE_VSTPOC_NO_CYCLE_DETECT for rollback. */
+static int vstpoc_cycle_detect_disabled( void )
+{
+    static int checked = 0;
+    static int disabled = 0;
+    if (!checked)
+    {
+        const char *e = getenv("WINE_VSTPOC_NO_CYCLE_DETECT");
+        disabled = (e && *e && *e != '0');
+        checked = 1;
+    }
+    return disabled;
+}
+
+static void vstpoc_cycle_timeout( void *private )
+{
+    struct message_result *result = private;
+
+    result->cycle_timeout = NULL;
+    if (result->replied) return;  /* race: real reply landed first */
+
+    /* Phase 1 (first fire): wake the receiver queue and re-arm — many JUCE
+     * deadlocks are "receiver hasn't reached a message pump yet"; waking
+     * QS_SENDMESSAGE forces MsgWaitForMultipleObjects to return so the
+     * message drains and the receiver replies for real. */
+    if (!result->cycle_wake_attempted && result->receiver)
+    {
+        result->cycle_wake_attempted = 1;
+        set_queue_bits( result->receiver, QS_SENDMESSAGE );
+        fprintf( stderr, "vstpoc cycle: threshold — phase 1 wake "
+                 "result=%p sender=%p receiver=%p msg=0x%04x\n",
+                 result, result->sender, result->receiver,
+                 result->cycle_orig_msg );
+        result->cycle_timeout = add_timeout_user(
+            VSTPOC_CYCLE_THRESHOLD, vstpoc_cycle_timeout, result );
+        return;
+    }
+
+    /* Phase 2 (second fire): receiver still stuck → synthesize 0-reply so
+     * the blocked sender returns, resumes its own pump, and the cycle breaks. */
+    fprintf( stderr, "vstpoc cycle: threshold — synthesizing 0-reply "
+             "result=%p sender=%p msg=0x%04x (phase 2)\n",
+             result, result->sender, result->cycle_orig_msg );
+    store_message_result( result, 0, 0 );
+}
