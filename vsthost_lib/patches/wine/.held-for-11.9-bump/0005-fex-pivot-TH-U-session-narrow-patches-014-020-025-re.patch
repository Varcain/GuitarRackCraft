-     * other timing-sensitive code paths. */
+    /* vstpoc: treat any timeout <= 500ms as polling. Infinite or long
+     * timeouts take the normal path to avoid disturbing audio or other
+     * timing-sensitive code paths. */
     BOOL vstpoc_short_timeout = (timeout && timeout->QuadPart < 0 &&
