+/* vstpoc patch 025: detect JUCE-7 popup-close cross-thread SendMessage cycle
+ * and break it by synthesizing a 0-reply once the receiver has held the
+ * message past a 500ms threshold without replying.
+ *
+ * Cycle pattern:
+ *   Thread A calls SendMessage cross-thread to thread B's window (sync).
+ *   A blocks in wait_message_reply.
+ *   B dequeues the message via get_message: the message_result is now on
+ *   B's recv_result stack with .replied=0 and .sender pointing to A.
+ *   B's WindowProc (JUCE handleFocusLoss) enters RtlWaitOnAddress polling
+ *   on a shared atomic. That atomic is only advanced by A's own posted-
+ *   message dispatch (WM_TIMER / WM_USER+123) — but A is blocked.
+ *   Deadlock: A waits for B's reply, B waits for A's posts.
+ *
+ * Fix: when receive_message moves a result to B's recv_result, schedule
+ * a 500ms timer (vstpoc_cycle_timeout). If the receiver hasn't replied
+ * by then, the timer fires and store_message_result(res, 0, 0) wakes A
+ * with a synthetic 0-reply. A returns from SendMessage, resumes its own
+ * pump, posted messages dispatch, atomic advances, B's polling loop
+ * exits, B's WindowProc returns. When B finally calls reply_message,
+ * reply_message sees res->replied==1 and skips the second
+ * store_message_result (existing path at line 1137).
+ *
+ * Why drag-drop is unaffected:
+ *   Drag-drop's per-message receiver-side handler completes in <10ms
+ *   typically (no polling). The 500ms timer is removed by store_message_result
+ *   long before it fires.
+ *
+ * Gated by env var WINE_VSTPOC_NO_CYCLE_DETECT for rollback. */
+
+static int vstpoc_cycle_detect_disabled( void )
+{
+    static int checked = 0;
+    static int disabled = 0;
+    if (!checked)
+    {
+        const char *e = getenv("WINE_VSTPOC_NO_CYCLE_DETECT");
+        disabled = (e && *e && *e != '0');
+        checked = 1;
+    }
+    return disabled;
+}
+
+static void vstpoc_cycle_timeout( void *private )
+{
+    struct message_result *result = private;
+
+    result->cycle_timeout = NULL;
+    if (result->replied) return;  /* race: real reply landed first */
+
+    fprintf( stderr, "vstpoc cycle: 500ms threshold — synthesizing 0-reply "
+             "result=%p sender=%p (focus msg)\n", result, result->sender );
+    store_message_result( result, 0, 0 );
+}
