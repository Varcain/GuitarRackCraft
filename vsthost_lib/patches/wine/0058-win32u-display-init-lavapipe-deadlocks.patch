+/* ===== vstpoc GL AHB-bounce zero-copy present ================================
+ * UNIVERSAL (not Adreno-tied) zero-copy GL editor present. The system EGL on this
+ * Qualcomm device — and Android GPU EGLs generally — imports AHardwareBuffers
+ * (EGL_ANDROID_image_native_buffer, CDD-mandated) but NOT raw dma-bufs (no
+ * EGL_EXT_image_dma_buf_import); the wine surfaceless Mesa EGL can EXPORT dma-bufs
+ * but can't make AHBs (no android platform). Bridge universally: allocate an AHB
+ * (NDK), get its OWN dma-buf fd (AHardwareBuffer_getNativeHandle->data[0]), import
+ * THAT into Mesa as a renderable FBO (EGL_LINUX_DMA_BUF_EXT — universal on Mesa),
+ * GPU-blit the editor's frame into it (no CPU copy), and ship the AHB over the
+ * same side-channel the Vulkan/DXVK path (0048) uses → the consumer imports it via
+ * the existing AHB path. CPU_READ usage forces LINEAR so the producer-side dma-buf
+ * import needs no modifier. The AHB is a SEPARATE buffer from the editor FBO ⇒ no
+ * tearing. Enabled by VSTPOC_AHB_GL=1 (opt-in for plugin prefixes) or
+ * VSTPOC_AHB_PRESENT=1; VSTPOC_AHB_GL=0 forces readback; any failure falls back.
+ * See feedback_gl_zerocopy_dmabuf_not_ahb. */
+
+/* EGL_EXT_image_dma_buf_import tokens (the wine Mesa EGL HAS this; absent from
+ * some wine egl headers). */
+#ifndef EGL_LINUX_DMA_BUF_EXT
+#define EGL_LINUX_DMA_BUF_EXT            0x3270
+#endif
+#ifndef EGL_LINUX_DRM_FOURCC_EXT
+#define EGL_LINUX_DRM_FOURCC_EXT         0x3271
+#define EGL_DMA_BUF_PLANE0_FD_EXT        0x3272
+#define EGL_DMA_BUF_PLANE0_OFFSET_EXT    0x3273
+#define EGL_DMA_BUF_PLANE0_PITCH_EXT     0x3274
+#endif
+/* Import the AHB's dma-buf as ARGB8888 (mem byte order B,G,R,A), NOT ABGR8888, so
+ * the producer's GL red lands in the B byte: the AHB then holds BGRA, which is what
+ * the X-server compositor expects (its shader swizzles .bgr, fbTex is BGRA-wire,
+ * the 0048 Vulkan/DXVK AHB is D3D BGRA). ABGR8888 would store RGBA → R/B swapped
+ * (blueish) after the shader's .bgr. */
+#define VSTPOC_DRM_ARGB8888 0x34325241u  /* 'AR24' */
+#define VSTPOC_AHB_FORMAT_RGBA8888 1u    /* AHARDWAREBUFFER_FORMAT_R8G8B8A8_UNORM */
+/* GPU_SAMPLED_IMAGE(0x100) | GPU_FRAMEBUFFER(0x200) | CPU_READ_RARELY(0x2): the CPU
+ * flag forces a LINEAR layout so the Mesa dma-buf import needs no modifier. */
+#define VSTPOC_AHB_USAGE 0x302ull
+
+/* NDK AHardwareBuffer_Desc / cutils native_handle_t, defined locally (win32u does
+ * not include the NDK headers). Layout matches android/hardware_buffer.h. */
+struct vstpoc_ahb_desc { UINT width, height, layers, format; UINT64 usage; UINT stride, rfu0; UINT64 rfu1; };
+struct vstpoc_native_handle { int version, num_fds, num_ints, data[1]; };
