+      pDesc->MinLuminance          = 0.5f;
+      pDesc->MaxLuminance          = 270.0f;
+      pDesc->MaxFullFrameLuminance = 270.0f;
+    } else {
+      pDesc->RedPrimary[0]         = m_metadata.redPrimary[0];
+      pDesc->RedPrimary[1]         = m_metadata.redPrimary[1];
