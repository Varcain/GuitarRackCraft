+/* vstpoc: Mesa's EGL-X11 software present (eglSwapBuffers) is a silent no-op
+ * against our in-process X server, which has no DRI3/Present and over which
+ * DMA-BUF/MIT-SHM aren't usable. Present manually instead: read the rendered
+ * frame back from the GL back buffer and XPutImage it onto the client X window,
+ * exactly like the Android offscreen->readback->XPutImage path. */
+#define VSTPOC_GL_BGRA          0x80E1
+#define VSTPOC_GL_UNSIGNED_BYTE 0x1401
+
+static void vstpoc_egl_readback_present( struct gl_drawable *gl )
+{
+    Window win = (Window)gl->drawable;   /* stored in x11drv_egl_surface_create */
+    XWindowAttributes wa;
+    XImage *img;
+    char *bottom_up, *top_down;
+    int w, h, y;
+    GC gc;
+
+    if (!win || !XGetWindowAttributes( gdi_display, win, &wa )) return;
+    w = wa.width; h = wa.height;
+    if (w <= 0 || h <= 0) return;
+
+    if (!(bottom_up = malloc( (size_t)w * h * 4 ))) return;
+    if (!(top_down = malloc( (size_t)w * h * 4 ))) { free( bottom_up ); return; }
+
+    funcs->p_glFinish();
+    funcs->p_glReadPixels( 0, 0, w, h, VSTPOC_GL_BGRA, VSTPOC_GL_UNSIGNED_BYTE, bottom_up );
+    /* GL's framebuffer origin is bottom-left, X11's is top-left: flip rows. */
+    for (y = 0; y < h; y++)
+        memcpy( top_down + (size_t)y * w * 4, bottom_up + (size_t)(h - 1 - y) * w * 4, (size_t)w * 4 );
+    free( bottom_up );
+
+    if ((img = XCreateImage( gdi_display, default_visual.visual, 32, ZPixmap, 0,
+                             top_down, w, h, 32, 0 )))
+    {
+        if ((gc = XCreateGC( gdi_display, win, 0, NULL )))
+        {
+            XPutImage( gdi_display, win, gc, img, 0, 0, 0, 0, w, h );
+            XFreeGC( gdi_display, gc );
+        }
+        XDestroyImage( img );   /* frees top_down */
+    }
+    else free( top_down );
+}
